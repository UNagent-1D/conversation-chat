SERVER_PORT=8082
APP_VERSION=1.0.0
GIN_MODE=debug

# Redis
REDIS_URL=redis://localhost:6379/0

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=conversatory

# External services
ACR_SERVICE_URL=http://localhost:8081
TENANT_SERVICE_URL=http://localhost:8080
AUTH_SERVICE_URL=http://localhost:9090

# OpenAI
OPENAI_API_KEY=sk-...

# Auth stub (dev only — set AUTH_STUB=true to bypass the auth service)
AUTH_STUB=true
AUTH_STUB_USER_ID=00000000-0000-0000-0000-000000000001
AUTH_STUB_ROLE=app_admin
AUTH_STUB_TENANT_ID=
AUTH_STUB_TENANT_SLUG=
AUTH_STUB_EMAIL=internal@platform.local

# Session defaults
DEFAULT_IDLE_TIMEOUT_SECONDS=300
